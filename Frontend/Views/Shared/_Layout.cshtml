@{
    var hideShell = ViewData["HideShell"] as bool? ?? false;
    var requestPath = Context.Request.Path.Value ?? string.Empty;
    var pageTitle = ViewData["Title"]?.ToString() ?? "AI Study Planner";
    var pageSubtitle = ViewData["Subtitle"]?.ToString() ?? "Plan, track, and keep your study rhythm moving.";
    var initials = string.Join(string.Empty,
        (User.Identity?.Name ?? "User")
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0])));

    string NavClass(string route) => requestPath.StartsWith(route, StringComparison.OrdinalIgnoreCase) ? "nav-link active" : "nav-link";

    string Icon(string name) => name switch
    {
        "home" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M4 10.5 12 4l8 6.5V20a1 1 0 0 1-1 1h-4.5v-6.5h-5V21H5a1 1 0 0 1-1-1v-9.5Z' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linejoin='round'/></svg>",
        "goals" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M6.5 5.5h11A1.5 1.5 0 0 1 19 7v10a1.5 1.5 0 0 1-1.5 1.5h-11A1.5 1.5 0 0 1 5 17V7a1.5 1.5 0 0 1 1.5-1.5Z' fill='none' stroke='currentColor' stroke-width='1.8'/><path d='M8 10h8M8 13h5' stroke='currentColor' stroke-width='1.8' stroke-linecap='round'/></svg>",
        "plus" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 5v14M5 12h14' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round'/></svg>",
        "calendar" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M7 4.5v2M17 4.5v2M5 9h14M6.5 6.5h11A1.5 1.5 0 0 1 19 8v10A1.5 1.5 0 0 1 17.5 19.5h-11A1.5 1.5 0 0 1 5 18V8a1.5 1.5 0 0 1 1.5-1.5Z' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linejoin='round'/></svg>",
        "chart" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M5.5 19.5h13A1.5 1.5 0 0 0 20 18V5' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round'/><path d='M8 16v-4M12 16V8M16 16v-6' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round'/></svg>",
        "timer" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M9 2.75h6M12 6v-2.5M12 21a7.5 7.5 0 1 0 0-15 7.5 7.5 0 0 0 0 15Z' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round' stroke-linejoin='round'/><path d='m12 12 2.5-1.5' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round'/></svg>",
        "user" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 12.25a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z' fill='none' stroke='currentColor' stroke-width='1.8'/><path d='M5.5 20a6.5 6.5 0 0 1 13 0' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round'/></svg>",
        "spark" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 3.75 13.8 9l5.2 1.8-5.2 1.8L12 17.8l-1.8-5.2L5 10.8 10.2 9 12 3.75Z' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linejoin='round'/></svg>",
        "bell" => "<svg viewBox='0 0 24 24' aria-hidden='true'><path d='M12 4a5 5 0 0 0-5 5v2.5c0 1.3-.4 2.5-1.2 3.5l-.3.4a1 1 0 0 0 .8 1.6h11.4a1 1 0 0 0 .8-1.6l-.3-.4c-.8-1-1.2-2.2-1.2-3.5V9a5 5 0 0 0-5-5Z' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linejoin='round'/><path d='M10.5 19.25a1.75 1.75 0 0 0 3 0' fill='none' stroke='currentColor' stroke-width='1.8' stroke-linecap='round'/></svg>",
        _ => string.Empty
    };
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - AI Study Planner</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@if (hideShell)
{
    <main class="auth-page">
        @RenderBody()
    </main>
}
else
{
    <div class="app-background"></div>
    <div class="page-shell app-shell">
        <aside class="sidebar glass-panel">
            <div class="brand-block">
                <div class="brand-mark">AI</div>
                <div>
                    <p class="eyebrow">Workspace</p>
                    <h2>Focus mode</h2>
                    <p>Plan smart, revise consistently, and stay ahead of deadlines.</p>
                </div>
            </div>

            <div class="sidebar-note">
                <div class="sidebar-note-dot"></div>
                <div>
                    <p class="sidebar-note-title">Connected</p>
                    <p class="sidebar-note-copy">API-backed study workspace</p>
                </div>
            </div>

            <nav class="sidebar-nav">
                <a class="@NavClass("/app/dashboard")" href="/app/dashboard">@Html.Raw(Icon("home"))<span>Dashboard</span></a>
                <a class="@NavClass("/app/goals")" href="/app/goals">@Html.Raw(Icon("goals"))<span>Goals</span></a>
                <a class="@NavClass("/app/goals/new")" href="/app/goals/new">@Html.Raw(Icon("plus"))<span>Create Goal</span></a>
                <a class="@NavClass("/app/planner")" href="/app/planner">@Html.Raw(Icon("calendar"))<span>Planner</span></a>
                <a class="@NavClass("/app/progress")" href="/app/progress">@Html.Raw(Icon("chart"))<span>Progress</span></a>
                <a class="@NavClass("/app/reminders")" href="/app/reminders">@Html.Raw(Icon("timer"))<span>Reminders</span></a>
                <a class="@NavClass("/app/profile")" href="/app/profile">@Html.Raw(Icon("user"))<span>Profile</span></a>
            </nav>

            <div class="sidebar-footer glass-panel">
                <p class="sidebar-footer-label">Signed in as</p>
                <p class="sidebar-footer-name">@User.Identity?.Name</p>
                <p class="sidebar-footer-copy">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</p>
            </div>
        </aside>

        <div class="main-column">
            <header class="navbar glass-panel topbar">
                <div class="page-header-copy">
                    <p class="eyebrow">@pageTitle</p>
                    <h1>@pageTitle</h1>
                    <p>@pageSubtitle</p>
                </div>

                <div class="navbar-actions">
                    <div class="status-chip hidden-on-mobile">
                        @Html.Raw(Icon("spark"))
                        <span>AI scheduling ready</span>
                    </div>

                    <div class="badge-circle accent hidden-on-mobile">
                        <span>@initials</span>
                    </div>

                    <div class="profile-copy hidden-on-mobile">
                        <p class="profile-name">@User.Identity?.Name</p>
                        <p class="profile-email">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</p>
                    </div>

                    <form method="post" asp-controller="Account" asp-action="Logout">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-ghost small">Logout</button>
                    </form>
                </div>
            </header>

            @if (TempData["SuccessMessage"] is string successMessage)
            {
                <div class="alert success">@successMessage</div>
            }
            @if (TempData["ErrorMessage"] is string errorMessage)
            {
                <div class="alert error">@errorMessage</div>
            }

            <main class="content-stack">
                @RenderBody()
            </main>
        </div>
    </div>
}

<script src="~/js/site.js" asp-append-version="true"></script>
@RenderSection("Scripts", required: false)
</body>
</html>