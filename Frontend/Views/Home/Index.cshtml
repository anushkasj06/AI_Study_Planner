@{
    ViewData["HideShell"] = true;
    ViewData["Title"] = "AI Study Planner";
    ViewData["Subtitle"] = "A focused workspace for goals, plans, reminders, and progress.";
}

<div class="landing-page">
    <div class="page-shell landing-shell">
        <header class="landing-header">
            <a class="landing-brand" href="/">
                <span class="brand-mark landing-brand-mark">AI</span>
                <span>
                    <p class="eyebrow">Portfolio Project</p>
                    <h1>AI Study Planner for Students</h1>
                </span>
            </a>
            <div class="landing-actions">
                <span class="status-chip subtle">AI ready</span>
                <a class="btn btn-secondary" href="/login">Login</a>
                <a class="btn btn-primary" href="/register">Get started</a>
            </div>
        </header>

        <section class="hero-grid">
            <div class="hero-copy">
                <div class="hero-badge">
                    <span class="spark-icon">✦</span>
                    <span>Gemini-powered schedules, reminders, and progress tracking</span>
                </div>
                <h2>Turn vague study goals into a realistic daily action plan.</h2>
                <p>
                    Students can create goals, generate structured study plans, track progress, manage reminders, and build momentum with a clean dashboard.
                </p>
                <div class="hero-actions">
                    <a class="btn btn-primary" href="/register">Start planning</a>
                    <a class="btn btn-secondary" href="/login">Login</a>
                </div>
                <div class="landing-metrics">
                    <div class="metric-tile glass-panel">
                        <span>Faster planning</span>
                        <strong>Adaptive daily tasks</strong>
                    </div>
                    <div class="metric-tile glass-panel">
                        <span>Better follow-through</span>
                        <strong>Reminders + streaks</strong>
                    </div>
                    <div class="metric-tile glass-panel">
                        <span>Clean tracking</span>
                        <strong>Goals, tasks, progress</strong>
                    </div>
                </div>
            </div>

            <div class="glass-panel feature-panel landing-stage">
                <div class="landing-stage-head">
                    <div>
                        <p class="eyebrow">Workspace preview</p>
                        <h3>What you can do</h3>
                    </div>
                    <span class="pill success">Live</span>
                </div>
                <div class="feature-list">
                    <div class="feature-item">
                        <span class="feature-mark">✓</span>
                        <p>Create semester, exam, or daily habit goals</p>
                    </div>
                    <div class="feature-item">
                        <span class="feature-mark">✓</span>
                        <p>Generate AI study plans as structured tasks</p>
                    </div>
                    <div class="feature-item">
                        <span class="feature-mark">✓</span>
                        <p>Track streaks, completion, and study hours</p>
                    </div>
                    <div class="feature-item">
                        <span class="feature-mark">✓</span>
                        <p>Manage in-app reminders with optional email support</p>
                    </div>
                </div>

                <div class="preview-panel glass-panel">
                    <div class="preview-panel-row">
                        <div>
                            <p class="preview-label">Today</p>
                            <strong>Study 2.5 hrs</strong>
                        </div>
                        <span class="pill brand">Focus</span>
                    </div>
                    <div class="preview-strip">
                        <span style="width: 78%"></span>
                    </div>
                    <div class="preview-footer">
                        <span>Progress kept in sync</span>
                        <span>AI scheduling on</span>
                    </div>
                </div>
            </div>
        </section>

        <footer class="app-footer glass-panel">
            <div>
                <p class="eyebrow">Built for focus</p>
                <h3>Clear planning, cleaner revision, fewer distractions.</h3>
                <p class="helper-copy">Goals, planner, reminders, notes, and progress live in one simple workspace.</p>
            </div>

            <div class="footer-links">
                <a href="/login">Login</a>
                <a href="/register">Register</a>
            </div>
        </footer>
    </div>
</div>