@model RegisterViewModel
@{
    ViewData["HideShell"] = true;
    ViewData["Title"] = "Register";
}

<section class="auth-card glass-panel">
    <div>
        <p class="eyebrow">New account</p>
        <h1>Create your planner profile</h1>
    </div>

    <form method="post" class="stack-form">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="field-error summary-error"></div>

        <label class="field">
            <span class="field-label">Full name</span>
            <input asp-for="FullName" class="field-control" placeholder="Full name" />
            <span asp-validation-for="FullName" class="field-error"></span>
        </label>

        <label class="field">
            <span class="field-label">Email</span>
            <input asp-for="Email" type="email" class="field-control" placeholder="Email" />
            <span asp-validation-for="Email" class="field-error"></span>
        </label>

        <label class="field">
            <span class="field-label">Phone number</span>
            <input asp-for="PhoneNumber" class="field-control" placeholder="+919876543210" />
            <span asp-validation-for="PhoneNumber" class="field-error"></span>
        </label>

        <label class="field">
            <span class="field-label">Password</span>
            <input asp-for="Password" type="password" class="field-control" placeholder="Password" />
            <span asp-validation-for="Password" class="field-error"></span>
        </label>

        <button type="submit" class="btn btn-primary full-width">Register</button>

        <p class="auth-link">
            Already have an account?
            <a href="/login">Log in</a>
        </p>
    </form>
</section>